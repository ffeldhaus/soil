{
  "name": "functions",
  "scripts": {
    "lint": "../../node_modules/.bin/biome check .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "node -e \"const {spawn}=require('child_process');const a=process.argv.slice(1).filter(x=>x!=='min'&&x!=='--reporter');spawn('npx',['vitest','run','--reporter','dot',...a],{stdio:'inherit',shell:true}).on('exit',process.exit)\" --",
    "test:coverage": "vitest run --coverage"
  },
  "nyc": {
    "extension": [
      ".ts"
    ],
    "require": [
      "ts-node/register"
    ],
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/**/*.test.ts",
      "src/types.ts",
      "src/index.ts"
    ],
    "reporter": [
      "text",
      "lcov"
    ],
    "all": true,
    "sourceMap": true,
    "instrument": true
  },
  "engines": {
    "node": "24"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google/genai": "^1.37.0",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.4",
    "google-auth-library": "^10.5.0",
    "nodemailer": "^7.0.13"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.0.10",
    "@types/nodemailer": "^7.0.9",
    "@types/sinon": "^21.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "chai": "^6.2.2",
    "firebase-functions-test": "^3.4.1",
    "mocha": "^11.7.5",
    "nyc": "^17.1.0",
    "sinon": "^21.0.1",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "private": true
}
